	overflow-wrap: break-word;
	word-break: break-word;
	white-space: normal;
	overflow: hidden;
}

.tc-resizable-table-cell {
	word-wrap: break-word;
	overflow-wrap: break-word;
	word-break: break-word;
	white-space: normal;
}

.tc-table-column-resizer {
	position: absolute;
	right: -4px;
	top: 0;
	bottom: 0;
	width: 8px;
