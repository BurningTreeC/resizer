		</div>
	</div>
</div>
\end

\function btc.rgrid.track.default-col-size(columns)
	[[100]divide<columns>fixed[6]addsuffix[%]]
\end

\function btc.rgrid.track.template(columns,defaultColSize)
	[range[1],<columns>]
	:map[[minmax(0, var(--btc-rgrid-col-]addsuffix<currentTiddler>addsuffix[, ]addsuffix<defaultColSize>addsuffix[))]]
	+[join[ ]]
\end

\function btc.rgrid.track.variables(statePrefix,columns,defaultColSize)
	[range[1],<columns>]
	:map[<statePrefix>addsuffix[/col-]addsuffix<currentTiddler>get[text]else<defaultColSize>addprefix[: ]addprefix<currentTiddler>addprefix[--btc-rgrid-col-]addsuffix[;]]
	+[join[ ]]
\end

