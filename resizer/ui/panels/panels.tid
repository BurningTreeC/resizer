\function btc.rgrid.track.default-col-size(columns)
	[[100]divide<columns>fixed[6]addsuffix[%]]
\end

\function btc.rgrid.track.template(columns,defaultColSize,colMinWidth)
	[range[1],<columns>]
	:map[[minmax(var(--btc-rgrid-col-]addsuffix<currentTiddler>addsuffix[-min, var(--btc-rgrid-col-min-width, ]addsuffix<colMinWidth>addsuffix[)), var(--btc-rgrid-col-]addsuffix<currentTiddler>addsuffix[, ]addsuffix<defaultColSize>addsuffix[))]]
	+[join[ ]]
\end

\function btc.rgrid.track.variable(statePrefix,index,columns,defaultColSize,fillLastColumn,lastColSize)
	[<fillLastColumn>match[yes]then<index>compare:integer:eq<columns>then[function[btc.rgrid.xy.track-state],<statePrefix>,[col],<index>,<lastColSize>then<lastColSize>]
	~[<fillLastColumn>match[yes]then<index>compare:integer:eq<columns>then<defaultColSize>]
	~[<statePrefix>addsuffix[/col-]addsuffix<index>get[text]]
	~[<defaultColSize>]
	+[addprefix[: ]addprefix<index>addprefix[--btc-rgrid-col-]addsuffix[;]]
\end

\function btc.rgrid.track.variables(statePrefix,columns,defaultColSize,fillLastColumn,lastColSize)
	[range[1],<columns>]
	:map[function[btc.rgrid.track.variable],<statePrefix>,<currentTiddler>,<columns>,<defaultColSize>,<fillLastColumn>,<lastColSize>]
	+[join[ ]]
\end

\function btc.rgrid.track.min-variable(statePrefix,index,columns,colMinWidth,fillLastColumn,lastColSize)
	[<fillLastColumn>match[yes]then<index>compare:integer:eq<columns>then<statePrefix>addsuffix[/col-]addsuffix<index>addsuffix[-min]get[text]trim[]!is[blank]]
	~[<fillLastColumn>match[yes]then<index>compare:integer:eq<columns>then<statePrefix>addsuffix[/col-]addsuffix<index>get[text]trim[]!is[blank]!match<lastColSize>]
	~[<colMinWidth>]
	+[addprefix[-min: ]addprefix<index>addprefix[--btc-rgrid-col-]addsuffix[;]]
\end

\function btc.rgrid.track.min-variables(statePrefix,columns,colMinWidth,fillLastColumn,lastColSize)
	[range[1],<columns>]
	:map[function[btc.rgrid.track.min-variable],<statePrefix>,<currentTiddler>,<columns>,<colMinWidth>,<fillLastColumn>,<lastColSize>]
	+[join[ ]]
\end

