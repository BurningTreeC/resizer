\procedure collapsible-master-detail-panel(masterContent:"", detailContent:"", collapsed:"no", size:"25%", minSize:"10%", maxSize:"40%", minHeight:"100%", stateTiddler:"$:/state/cmdp/size", detailStateTiddler:"$:/state/cmdp/detail", collapseStateTiddler:"$:/state/cmdp/collapsed", class:"", masterClass:"", detailClass:"", splitterClass:"")
\whitespace trim
<$let
	isCollapsed={{{ [<collapseStateTiddler>get[text]else<collapsed>] }}}
	masterWidth={{{ [<stateTiddler>get[text]else<size>] }}}
	detailWidth={{{ [<detailStateTiddler>get[text]else[calc(100% - ]addsuffix<masterWidth>addsuffix[)]] }}}
	panelId=<<qualify>>
	data-panel-id-selector='[data-tf-panel-id="'
	data-panel-id-selector-close='"]'
	masterSelector={{{ [[.tc-master-panel]addsuffix<data-panel-id-selector>addsuffix<panelId>addsuffix<data-panel-id-selector-close>] }}}
	detailSelector={{{ [[.tc-detail-panel]addsuffix<data-panel-id-selector>addsuffix<panelId>addsuffix<data-panel-id-selector-close>] }}}
>
<div
	class={{{ tc-collapsible-master-detail [<class>] +[join[ ]] }}}
	style.display="flex"
	style.flex-direction="row"
	style.min-height=<<minHeight>>
	style.width="100%"
	style.max-width="100%"
	style.min-width="0"
	style.overflow="hidden"
>
	<%if [<isCollapsed>match[no]] %>
		<$button class="tc-btn-invisible tc-panel-collapse-btn" set=<<collapseStateTiddler>> setTo="yes">
			{{$:/core/images/chevron-left}}
		</$button>
	<% else %>
		<$button class="tc-btn-invisible tc-panel-expand-btn" set=<<collapseStateTiddler>> setTo="no">
			{{$:/core/images/chevron-right}}
		</$button>
	<% endif %>

	<div
		data-tf-panel-id=<<panelId>>
		class={{{ [<isCollapsed>match[yes]then[tc-master-panel tc-collapsed]else[tc-master-panel]] [<masterClass>] +[join[ ]] }}}
		style.flex={{{ [<isCollapsed>match[yes]then[0 0 0px]else[0 0 ]addsuffix<masterWidth>] }}}
		style.flex-basis={{{ [<isCollapsed>match[yes]then[0px]else<masterWidth>] }}}
		style.width={{{ [<isCollapsed>match[yes]then[0px]else<masterWidth>] }}}
		style.min-width={{{ [<isCollapsed>match[yes]then[0px]else<minSize>] }}}
		style.max-width=<<maxSize>>
		style.overflow={{{ [<isCollapsed>match[yes]then[hidden]else[auto]] }}}
	>
		<$transclude $variable="tf.panel-content" content=<<masterContent>>/>
	</div>

	<%if [<isCollapsed>match[no]] %>
		<$resizer
			class={{{ tc-panel-splitter-vertical [<splitterClass>] +[join[ ]] }}}
			direction="horizontal"
			mode="split-pair"
			leftSelector=<<masterSelector>>
			rightSelector=<<detailSelector>>
			leftTiddler=<<stateTiddler>>
			rightTiddler=<<detailStateTiddler>>
			leftField="text"
			rightField="text"
			min=<<minSize>>
			max=<<maxSize>>
			default=<<size>>
			unit={{{ [tf.get.value.metric<size>] }}}
			property="flexBasis"
			splitPairLiveResize="yes"
			splitPairSave="end"
		/>
	<% endif %>

	<div
		data-tf-panel-id=<<panelId>>
		class={{{ tc-detail-panel [<detailClass>] +[join[ ]] }}}
		style.flex={{{ [<isCollapsed>match[yes]then[1 1 auto]else[0 0 ]addsuffix<detailWidth>] }}}
		style.flex-basis={{{ [<isCollapsed>match[yes]then[auto]else<detailWidth>] }}}
		style.width={{{ [<isCollapsed>match[yes]then[auto]else<detailWidth>] }}}
		style.min-width="0"
		style.overflow="auto"
	>
		<$transclude $variable="tf.panel-content" content=<<detailContent>>/>
	</div>
</div>
</$let>
\end

\procedure collapsible-three-column-panels(leftContent:"", centerContent:"", rightContent:"", leftWidth:"10%", centerWidth:"", rightWidth:"10%", minWidth:"5%", maxWidth:"80%", minHeight:"100%", leftStateTiddler:"$:/state/three-col-collapsible/left", centerStateTiddler:"$:/state/three-col-collapsible/center", rightStateTiddler:"$:/state/three-col-collapsible/right", class:"", leftClass:"", centerClass:"", rightClass:"", splitterClass:"", collapsedLeft:"no", collapsedRight:"no", collapseStateTiddlerLeft:"$:/state/ctcp/left", collapseStateTiddlerRight:"$:/state/ctcp/right")
