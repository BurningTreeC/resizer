			~[<btcRgridDefaultCellMode>match[inline]then[inline]]
			~[[block]]
		}}}
		isLastColumn={{{ [<colBoundaryIndex>compare:integer:gteq<btcRgridColumns>then[yes]else[no]] }}}
		isLastRow={{{ [<rowBoundaryIndex>compare:integer:gteq<btcRgridRows>then[yes]else[no]] }}}
