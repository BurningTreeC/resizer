			[all[current]tag[Muted]then[btc-rgrid-cell-muted]]
			+[join[ ]]
		}}}
	>
		<div
			class={{{ [[btc-rgrid-cell btc-rgrid-cell-real ]addsuffix<cellClass>] }}}
			data-title=<<tiddler>>
