		data-tf-panel-id=<<panelId>>
		class={{{ [<rightCollapsed>match[yes]then[tc-panel-right tc-collapsed]else[tc-panel-right]] [<rightClass>] +[join[ ]] }}}
		style.flex={{{ [<rightCollapsed>match[yes]then[0 0 0px]else[0 0 ]addsuffix<rightCurrentWidth>] }}}
		style.flex-basis={{{ [<rightCollapsed>match[yes]then[0px]else<rightCurrentWidth>] }}}
		style.width={{{ [<rightCollapsed>match[yes]then[0px]else<rightCurrentWidth>] }}}
		style.min-width={{{ [<rightCollapsed>match[yes]then[0px]else<minWidth>] }}}
		style.max-width=<<maxWidth>>
