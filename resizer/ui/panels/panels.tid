\procedure btc.rgrid.track.cell(col:"auto",row:"auto",colSpan:"1",rowSpan:"1",last:"no",resize:"yes",class:"",title:"",content:"")
<$let boundaryIndex={{{ [<col>match[auto]then[]] ~[<col>add<colSpan>subtract[1]] }}}>
<div
	class={{{ [[btc-rgrid-cell ]addsuffix<class>] }}}
	data-col=<<col>>
	data-row=<<row>>
	data-col-span=<<colSpan>>
	data-row-span=<<rowSpan>>
	style.grid-column={{{ [<col>addsuffix[ / span ]addsuffix<colSpan>] }}}
	style.grid-row={{{ [<row>addsuffix[ / span ]addsuffix<rowSpan>] }}}
>
	<div class="btc-rgrid-cell-content">
		<$list filter="[<title>!is[blank]]">
			<div class="btc-rgrid-cell-title"><<title>></div>
		</$list>
		<$transclude $variable="content" $mode="block"/>
	</div>
	<$list filter="[<resize>match[yes]]">
		<$list filter="[<last>!match[yes]]">
			<$list filter="[<boundaryIndex>!is[blank]]">
				<$transclude $variable="btc.rgrid.track.handle" index=<<boundaryIndex>>/>
			</$list>
		</$list>
	</$list>
</div>
</$let>
\end

\procedure btc.rgrid.track.header(col:"auto",row:"auto",colSpan:"1",rowSpan:"1",last:"no",resize:"yes",class:"",content:"")
<$transclude
	$variable="btc.rgrid.track.cell"
	col=<<col>>
	row=<<row>>
	colSpan=<<colSpan>>
	rowSpan=<<rowSpan>>
	last=<<last>>
	resize=<<resize>>
	class={{{ [[btc-rgrid-cell-header ]addsuffix<class>] }}}
	content=<<content>>
/>
\end

\procedure btc.rgrid.track.handle(index:"1")
<$resizer
	mode="grid-track"
	class="btc-rgrid-cell-resizer"
	direction="horizontal"
	gridSelector=<<btcRgridSelector>>
	gridTrackIndex=<<index>>
	gridTrackStatePrefix=<<btcRgridStatePrefix>>
	gridTrackUnit=<<btcRgridUnit>>
	gridTrackMin=<<btcRgridMinColSize>>
	gridTrackMax=<<btcRgridMaxColSize>>
	gridTrackLive="yes"
	gridTrackSave="end"
	gridTrackLiveUnit="px"
	gridTrackSaveUnit="px"
	gridTrackFreezeOnStart="yes"
	gridTrackFreezeOnEnd="yes"
/>
\end

\function btc.rgrid.placed.default-col-size(columns)
	[[100]divide<columns>fixed[6]addsuffix[%]]
\end

\function btc.rgrid.placed.columns-template(columns,defaultColSize)
	[range[1],<columns>]
	:map[[minmax(0, var(--btc-rgrid-col-]addsuffix<currentTiddler>addsuffix[, ]addsuffix<defaultColSize>addsuffix[))]]
	+[join[ ]]
\end

\function btc.rgrid.placed.column-variables(statePrefix,columns,defaultColSize)
	[range[1],<columns>]
	:map[<statePrefix>addsuffix[/col-]addsuffix<currentTiddler>get[text]else<defaultColSize>addprefix[: ]addprefix<currentTiddler>addprefix[--btc-rgrid-col-]addsuffix[;]]
	+[join[ ]]
\end

\function btc.rgrid.placed.rows-template(rows,defaultRowSize)
	[range[1],<rows>]
	:map[[minmax(var(--btc-rgrid-row-min-height), ]addsuffix<defaultRowSize>addsuffix[)]]
	+[join[ ]]
\end

\function btc.rgrid.placed.occupied(tag,row,col)
	[tag<tag>]
	:filter[<currentTiddler>get[row]else[0]compare:integer:lteq<row>]
	:filter[<currentTiddler>get[col]else[0]compare:integer:lteq<col>]
	:filter[<currentTiddler>get[row]else[0]add{!!rowspan}subtract[1]compare:integer:gteq<row>]
	:filter[<currentTiddler>get[col]else[0]add{!!colspan}subtract[1]compare:integer:gteq<col>]
	+[limit[1]]
\end

\procedure btc.rgrid.placed.table(gridId:"placed-default",tag:"TableCell",columns:"4",rows:"4",statePrefix:"$:/state/btc/rgrid/placed/default",defaultColSize:"",defaultRowSize:"auto",rowMinHeight:"3rem",cellGap:"0.35rem",minColSize:"4%",maxColSize:"90%",unit:"%",class:"",sortField:"order",showTitles:"no")
<$let
	effectiveDefaultColSize={{{ [<defaultColSize>!is[blank]then<defaultColSize>] ~[function[btc.rgrid.placed.default-col-size],<columns>] }}}
	btcRgridGridId=<<gridId>>
	btcRgridColumns=<<columns>>
	btcRgridStatePrefix=<<statePrefix>>
	btcRgridDefaultColSize=<<effectiveDefaultColSize>>
	btcRgridMinColSize=<<minColSize>>
	btcRgridMaxColSize=<<maxColSize>>
	btcRgridUnit=<<unit>>
	btcRgridSelector={{{ [[.btc-rgrid-instance-]addsuffix<gridId>] }}}
	btcRgridColumnTemplate={{{ [function[btc.rgrid.placed.columns-template],<columns>,<effectiveDefaultColSize>] }}}
	btcRgridColumnVariables={{{ [function[btc.rgrid.placed.column-variables],<statePrefix>,<columns>,<effectiveDefaultColSize>] }}}
	btcRgridRowsTemplate={{{ [function[btc.rgrid.placed.rows-template],<rows>,<defaultRowSize>] }}}
	btcRgridStyle={{{ [[--btc-rgrid-columns-template: ]addsuffix<btcRgridColumnTemplate>addsuffix[; --btc-rgrid-rows-template: ]addsuffix<btcRgridRowsTemplate>addsuffix[; --btc-rgrid-row-min-height: ]addsuffix<rowMinHeight>addsuffix[; --btc-rgrid-cell-gap: ]addsuffix<cellGap>addsuffix[; ]addsuffix<btcRgridColumnVariables>] }}}
>
<div
	class={{{ [[btc-rgrid-table btc-rgrid-instance-]addsuffix<gridId>addsuffix[ ]addsuffix<class>] }}}
	style=<<btcRgridStyle>>
	data-btc-rgrid-id=<<gridId>>
	data-tag=<<tag>>
	data-columns=<<columns>>
	data-rows=<<rows>>
>
	<div class="btc-rgrid-content">
		<$list filter="[range[1],<rows>]">
			<$let ghostRow=<<currentTiddler>>>
				<$list filter="[range[1],<columns>]">
					<$let ghostCol=<<currentTiddler>>>
						<$list filter="[function[btc.rgrid.placed.occupied],<tag>,<ghostRow>,<ghostCol>count[]match[0]]">
							<$transclude
								$variable="btc.rgrid.placed.ghost"
								row=<<ghostRow>>
								col=<<ghostCol>>
							/>
						</$list>
					</$let>
				</$list>
			</$let>
		</$list>

		<$list filter="[tag<tag>sortan<sortField>]">
			<$transclude
				$variable="btc.rgrid.placed.cell"
				tiddler=<<currentTiddler>>
				showTitle=<<showTitles>>
			/>
		</$list>
	</div>
</div>
</$let>
\end

\procedure btc.rgrid.placed.ghost(row:"1",col:"1")
<$let
	boundaryIndex=<<col>>
	isLastColumn={{{ [<col>compare:integer:gteq<btcRgridColumns>then[yes]else[no]] }}}
>
<div
	class="btc-rgrid-cell btc-rgrid-cell-ghost"
	data-ghost="yes"
	data-row=<<row>>
	data-col=<<col>>
	data-boundary-index=<<boundaryIndex>>
	style.grid-area={{{ [<row>addsuffix[ / ]addsuffix<col>addsuffix[ / span 1 / span 1]] }}}
>
	<div class="btc-rgrid-cell-content"></div>

	<$list filter="[<isLastColumn>!match[yes]]">
		<$transclude
			$variable="btc.rgrid.placed.handle"
			index=<<boundaryIndex>>
		/>
	</$list>
</div>
</$let>
\end

\procedure btc.rgrid.placed.cell(tiddler:"",showTitle:"no")
<$let
	col={{{ [<tiddler>get[col]else[1]] }}}
	row={{{ [<tiddler>get[row]else[1]] }}}
	colspan={{{ [<tiddler>get[colspan]else[1]] }}}
	rowspan={{{ [<tiddler>get[rowspan]else[1]] }}}
	boundaryIndex={{{ [<tiddler>get[col]else[1]add{!!colspan}subtract[1]] }}}
	isLastColumn={{{ [<boundaryIndex>compare:integer:gteq<btcRgridColumns>then[yes]else[no]] }}}
	cellClass={{{
		[<tiddler>tag[Header]then[btc-rgrid-cell-header]]
		[<tiddler>tag[Footer]then[btc-rgrid-cell-footer]]
		[<tiddler>tag[Muted]then[btc-rgrid-cell-muted]]
		+[join[ ]]
	}}}
>
<div
	class={{{ [[btc-rgrid-cell btc-rgrid-cell-real ]addsuffix<cellClass>] }}}
	data-title=<<tiddler>>
	data-col=<<col>>
	data-row=<<row>>
	data-colspan=<<colspan>>
	data-rowspan=<<rowspan>>
	data-boundary-index=<<boundaryIndex>>
	style.grid-area={{{ [<row>addsuffix[ / ]addsuffix<col>addsuffix[ / span ]addsuffix<rowspan>addsuffix[ / span ]addsuffix<colspan>] }}}
>
	<div class="btc-rgrid-cell-content">
		<$list filter="[<showTitle>match[yes]]">
			<div class="btc-rgrid-cell-title">
				<$link to=<<tiddler>>>
					<$text text=<<tiddler>>/>
				</$link>
			</div>
		</$list>
		<$transclude tiddler=<<tiddler>> mode="block"/>
	</div>

	<$list filter="[<isLastColumn>!match[yes]]">
		<$transclude
			$variable="btc.rgrid.placed.handle"
			index=<<boundaryIndex>>
		/>
	</$list>
</div>
</$let>
\end

