\procedure collapsible-three-row-panels(topContent:"", centerContent:"", bottomContent:"", topHeight:"10vh", centerHeight:"", bottomHeight:"10vh", minHeight:"5vh", maxHeight:"55vh", width:"100%", overallHeight:"75vh", topStateTiddler:"$:/state/three-col-collapsible-vertical/top", centerStateTiddler:"$:/state/three-col-collapsible-vertical/center", bottomStateTiddler:"$:/state/three-col-collapsible-vertical/bottom", class:"", topClass:"", centerClass:"", bottomClass:"", splitterClass:"", collapsedTop:"no", collapsedBottom:"no", collapseStateTiddlerTop:"$:/state/ctcpv/top", collapseStateTiddlerBottom:"$:/state/ctcpv/bottom")
\whitespace trim
<$let
	topCollapsed={{{ [<collapseStateTiddlerTop>get[text]else<collapsedTop>] }}}
	bottomCollapsed={{{ [<collapseStateTiddlerBottom>get[text]else<collapsedBottom>] }}}
	topCurrentHeight={{{ [<topStateTiddler>get[text]else<topHeight>] }}}
	bottomCurrentHeight={{{ [<bottomStateTiddler>get[text]else<bottomHeight>] }}}
	centerFallbackHeight={{{ [<centerHeight>!is[blank]else<tf.panel.center.height>] }}}
	centerCurrentHeight={{{ [<centerStateTiddler>get[text]else<centerFallbackHeight>] }}}
	panelId=<<qualify>>
	data-panel-id-selector='[data-tf-panel-id="'
	data-panel-id-selector-close='"]'
	topSelector={{{ [[.tc-panel-top]addsuffix<data-panel-id-selector>addsuffix<panelId>addsuffix<data-panel-id-selector-close>] }}}
	centerSelector={{{ [[.tc-panel-center-vertical]addsuffix<data-panel-id-selector>addsuffix<panelId>addsuffix<data-panel-id-selector-close>] }}}
	bottomSelector={{{ [[.tc-panel-bottom]addsuffix<data-panel-id-selector>addsuffix<panelId>addsuffix<data-panel-id-selector-close>] }}}
>
<div
	class={{{ tc-three-row-panels tc-collapsible-three-row-panels [<class>] +[join[ ]] }}}
	style.display="flex"
	style.flex-direction="column"
	style.width=<<width>>
	style.min-width="0"
	style.max-width=<<width>>
	style.height=<<overallHeight>>
	style.max-height=<<overallHeight>>
	style.min-height="0"
	style.overflow="hidden"
>
	<%if [<topCollapsed>match[no]] %>
		<$button class="tc-btn-invisible tc-panel-collapse-btn tc-panel-btn-top" set=<<collapseStateTiddlerTop>> setTo="yes">
			{{$:/core/images/chevron-left}}
		</$button>
	<% else %>
		<$button class="tc-btn-invisible tc-panel-expand-btn tc-panel-btn-top" set=<<collapseStateTiddlerTop>> setTo="no">
			{{$:/core/images/chevron-right}}
		</$button>
	<% endif %>

	<%if [<bottomCollapsed>match[no]] %>
		<$button class="tc-btn-invisible tc-panel-collapse-btn tc-panel-btn-bottom" set=<<collapseStateTiddlerBottom>> setTo="yes">
			{{$:/core/images/chevron-right}}
		</$button>
	<% else %>
		<$button class="tc-btn-invisible tc-panel-expand-btn tc-panel-btn-bottom" set=<<collapseStateTiddlerBottom>> setTo="no">
			{{$:/core/images/chevron-left}}
		</$button>
	<% endif %>

	<div
		data-tf-panel-id=<<panelId>>
		class={{{ [<topCollapsed>match[yes]then[tc-panel-top tc-collapsed]else[tc-panel-top]] [<topClass>] +[join[ ]] }}}
		style.flex={{{ [<topCollapsed>match[yes]then[0 0 0px]else[0 0 ]addsuffix<topCurrentHeight>] }}}
		style.flex-basis={{{ [<topCollapsed>match[yes]then[0px]else<topCurrentHeight>] }}}
		style.height={{{ [<topCollapsed>match[yes]then[0px]else<topCurrentHeight>] }}}
		style.min-height={{{ [<topCollapsed>match[yes]then[0px]else<minHeight>] }}}
		style.max-height=<<maxHeight>>
		style.max-width="100%"
		style.overflow={{{ [<topCollapsed>match[yes]then[hidden]else[auto]] }}}
	>
		<$transclude $variable="tf.panel-content" content=<<topContent>>/>
	</div>

	<%if [<topCollapsed>match[no]] %>
		<$resizer
			class={{{ tc-panel-splitter-horizontal [<splitterClass>] +[join[ ]] }}}
			direction="vertical"
			mode="split-pair"
			topSelector=<<topSelector>>
			bottomSelector=<<centerSelector>>
			topTiddler=<<topStateTiddler>>
			bottomTiddler=<<centerStateTiddler>>
			topField="text"
			bottomField="text"
			min=<<minHeight>>
			max=<<maxHeight>>
			default=<<topHeight>>
			unit={{{ [tf.get.value.metric<topHeight>] }}}
			property="flexBasis"
			splitPairLiveResize="yes"
			splitPairSave="end"
		/>
	<% endif %>

	<div
		data-tf-panel-id=<<panelId>>
		class={{{ tc-panel-center-vertical [<centerClass>] +[join[ ]] }}}
		style.flex={{{ [tf.panel.flex<centerCurrentHeight>] }}}
		style.flex-basis=<<centerCurrentHeight>>
		style.height=<<centerCurrentHeight>>
		style.min-height=<<minHeight>>
		style.max-width="100%"
		style.overflow="auto"
	>
		<div style.height="100%" style.min-height="0" style.display="flex" style.justify-content="center" style.overflow="auto">
			<$transclude $variable="tf.panel-content" content=<<centerContent>>/>
		</div>
	</div>

	<%if [<bottomCollapsed>match[no]] %>
		<$resizer
			class={{{ tc-panel-splitter-horizontal [<splitterClass>] +[join[ ]] }}}
			direction="vertical"
			mode="split-pair"
			topSelector=<<centerSelector>>
			bottomSelector=<<bottomSelector>>
			topTiddler=<<centerStateTiddler>>
			bottomTiddler=<<bottomStateTiddler>>
			topField="text"
			bottomField="text"
			min=<<minHeight>>
			max=<<maxHeight>>
			default=<<centerFallbackHeight>>
			unit={{{ [tf.get.value.metric<topHeight>] }}}
			property="flexBasis"
			splitPairLiveResize="yes"
			splitPairSave="end"
		/>
	<% endif %>

	<div
		data-tf-panel-id=<<panelId>>
		class={{{ [<bottomCollapsed>match[yes]then[tc-panel-bottom tc-collapsed]else[tc-panel-bottom]] [<bottomClass>] +[join[ ]] }}}
		style.flex={{{ [<bottomCollapsed>match[yes]then[0 0 0px]else[0 0 ]addsuffix<bottomCurrentHeight>] }}}
		style.flex-basis={{{ [<bottomCollapsed>match[yes]then[0px]else<bottomCurrentHeight>] }}}
		style.height={{{ [<bottomCollapsed>match[yes]then[0px]else<bottomCurrentHeight>] }}}
		style.min-height={{{ [<bottomCollapsed>match[yes]then[0px]else<minHeight>] }}}
		style.max-height=<<maxHeight>>
		style.max-width="100%"
		style.overflow={{{ [<bottomCollapsed>match[yes]then[hidden]else[auto]] }}}
	>
		<$transclude $variable="tf.panel-content" content=<<bottomContent>>/>
	</div>
</div>
</$let>
\end

